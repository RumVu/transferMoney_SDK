{"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TransferMoney_core","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Các cặp tiền tệ được hỗ trợ","type":"heading","anchor":"C%C3%A1c-c%E1%BA%B7p-ti%E1%BB%81n-t%E1%BB%87-%C4%91%C6%B0%E1%BB%A3c-h%E1%BB%97-tr%E1%BB%A3","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"VND ↔ USD"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"USD ↔ AUD","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"VND ↔ AUD "},{"inlineContent":[{"text":"(tự động qua USD trung gian)","type":"text"}],"type":"emphasis"}]}]}]},{"text":"Quick Start","anchor":"Quick-Start","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["\/\/ 1. Khởi tạo","let converter = TransferMoney_core()","","\/\/ 2. VND → USD với tỷ giá mặc định","let result = try converter.convert(amount: 1_000_000, from: .VND, to: .USD, choose: .standard)","print(result.targetAmount)          \/\/ 39.292...","print(result.FormattedTargetAmount) \/\/ \"$ 39.2927\"","","\/\/ 3. USD → AUD","let result2 = try converter.convert(amount: 100, from: .USD, to: .AUD, choose: .standard)","","\/\/ 4. VND → AUD (qua USD trung gian)","let result3 = try converter.convert(amount: 5_000_000, from: .VND, to: .AUD, choose: .standard)","","\/\/ 5. Tỷ giá tuỳ chỉnh","let result4 = try converter.convert(amount: 1_000_000, from: .VND, to: .USD, choose: .customRate(25_800))","","\/\/ 6. Shorthand — chỉ lấy số tiền","let usd = try converter.vndToUsd(1_000_000) \/\/ → 39.292...","let vnd = try converter.usdToVnd(10)         \/\/ → 254500.0"]},{"text":"Xử lý lỗi","anchor":"X%E1%BB%AD-l%C3%BD-l%E1%BB%97i","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["do {","    let result = try converter.convert(amount: -100, from: .VND, to: .USD, choose: .standard)","} catch CurrenciesError.invalidAmount(let msg) {","    print(msg)","} catch CurrenciesError.invalidExchangeRates(let rate) {","    print(\"Tỷ giá không hợp lệ: \\(rate)\")","} catch CurrenciesError.unsupportedConversion(let from, let to) {","    print(\"Chưa hỗ trợ \\(from.rawValue) → \\(to.rawValue)\")","}"]},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"Class này là "},{"type":"codeVoice","code":"final"},{"type":"text","text":" — không thể kế thừa."}],"type":"paragraph"}],"type":"aside","style":"note"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK"]]},"abstract":[{"type":"strong","inlineContent":[{"type":"text","text":"Đây là class duy nhất bạn cần dùng"}]},{"type":"text","text":" để thực hiện chuyển đổi tiền tệ giữa VND, USD, và AUD."}],"seeAlsoSections":[{"anchor":"Core-API","identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoneySDK","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/ConversionConfigs","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/ConversionResults","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/ConversionOption","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/Currency","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/CurrenciesError"],"generated":true,"title":"Core API"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/transfermoney_sdk\/transfermoney_core"]}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init()","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init(config:)"],"generated":true,"title":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc:\/\/transferMoney_SDK\/docu