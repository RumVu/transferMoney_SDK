ciesError.invalidExchangeRates(let rate) {","    print(\"Tỷ giá không hợp lệ: \\(rate)\")","} catch CurrenciesError.unsupportedConversion(let from, let to) {","    print(\"Chưa hỗ trợ \\(from.rawValue) → \\(to.rawValue)\")","}"]},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"Class này là ","type":"text"},{"code":"final","type":"codeVoice"},{"text":" — không thể kế thừa.","type":"text"}],"type":"paragraph"}],"name":"Note"}]}],"identifier":{"url":"doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Core API","generated":true,"identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoneySDK","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/ConversionConfigs","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/ConversionResults","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/ConversionOption","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/Currency","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/CurrenciesError"],"anchor":"Core-API"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://transferMoney_SDK/documentation/transferMoney_SDK/TransferMoney_core/init(config:)":{"url":"\/documentation\/transfermoney_sdk\/transfermoney_core\/init(config:)","title":"init(config:)","kind":"symbol","type":"topic","abstract":[{"text":"Tạo converter với cấu hình tuỳ chỉnh.","type":"text"}],"identifier":"doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init(config:)","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"config","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConversionConfigs","preciseIdentifier":"s:17transferMoney_SDK17ConversionConfigsV","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"doc://transferMoney_SDK/documentation/transferMoney_SDK/TransferMoney