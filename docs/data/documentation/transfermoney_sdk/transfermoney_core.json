{"metadata":{"symbolKind":"class","externalID":"s:17transferMoney_SDK08TransferB5_coreC","modules":[{"name":"transferMoney SDK"}],"roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TransferMoney_core","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"TransferMoney_core"}],"role":"symbol","title":"TransferMoney_core"},"sections":[],"hierarchy":{"paths":[["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK"]]},"abstract":[{"type":"strong","inlineContent":[{"type":"text","text":"Đây là class duy nhất bạn cần dùng"}]},{"type":"text","text":" để thực hiện chuyển đổi tiền tệ giữa VND, USD, và AUD."}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init()","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init(config:)"],"anchor":"Initializers"},{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/config"],"anchor":"Instance-Properties"},{"title":"Instance Methods","generated":true,"identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/convert(amount:from:to:choose:)","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/updateExchangeRates(_:)","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/usdToVnd(_:)","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/vndToUsd(_:)"],"anchor":"Instance-Methods"}],"variants":[{"paths":["\/documentation\/transfermoney_sdk\/transfermoney_core"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind"