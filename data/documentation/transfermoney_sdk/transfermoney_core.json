"anchor":"Quick-Start"},{"type":"codeListing","code":["\/\/ 1. Khởi tạo","let converter = TransferMoney_core()","","\/\/ 2. VND → USD với tỷ giá mặc định","let result = try converter.convert(amount: 1_000_000, from: .VND, to: .USD, choose: .standard)","print(result.targetAmount)          \/\/ 39.292...","print(result.FormattedTargetAmount) \/\/ \"$ 39.2927\"","","\/\/ 3. USD → AUD","let result2 = try converter.convert(amount: 100, from: .USD, to: .AUD, choose: .standard)","","\/\/ 4. VND → AUD (qua USD trung gian)","let result3 = try converter.convert(amount: 5_000_000, from: .VND, to: .AUD, choose: .standard)","","\/\/ 5. Tỷ giá tuỳ chỉnh","let result4 = try converter.convert(amount: 1_000_000, from: .VND, to: .USD, choose: .customRate(25_800))","","\/\/ 6. Shorthand — chỉ lấy số tiền","let usd = try converter.vndToUsd(1_000_000) \/\/ → 39.292...","let vnd = try converter.usdToVnd(10)         \/\/ → 254500.0"],"syntax":"swift"},{"type":"heading","text":"Xử lý lỗi","level":2,"anchor":"X%E1%BB%AD-l%C3%BD-l%E1%BB%97i"},{"type":"codeListing","code":["do {","    let result = try converter.convert(amount: -100, from: .VND, to: .USD, choose: .standard)","} catch CurrenciesError.invalidAmount(let msg) {","    print(msg)","} catch CurrenciesError.invalidExchangeRates(let rate) {","    print(\"Tỷ giá không hợp lệ: \\(rate)\")","} catch CurrenciesError.unsupportedConversion(let from, let to) {","    print(\"Chưa hỗ trợ \\(from.rawValue) → \\(to.rawValue)\")","}"],"syntax":"swift"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Class này là "},{"code":"final","type":"codeVoice"},{"type":"text","text":" — không thể kế thừa."}],"type":"paragraph"}],"type":"aside","name":"Note"}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/transfermoney_sdk\/transfermoney_core"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"strong","inlineContent":[{"type":"text","text":"Đây là class duy nhất bạn cần dùng"}]},{"type":"text","text":" để thực hiệ