{"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"TransferMoney_core"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Các cặp tiền tệ được hỗ trợ","anchor":"C%C3%A1c-c%E1%BA%B7p-ti%E1%BB%81n-t%E1%BB%87-%C4%91%C6%B0%E1%BB%A3c-h%E1%BB%97-tr%E1%BB%A3"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"VND ↔ USD"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"USD ↔ AUD"}]}]},{"content":[{"inlineContent":[{"text":"VND ↔ AUD ","type":"text"},{"inlineContent":[{"type":"text","text":"(tự động qua USD trung gian)"}],"type":"emphasis"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","text":"Quick Start","anchor":"Quick-Start"},{"type":"codeListing","code":["\/\/ 1. Khởi tạo","let converter = TransferMoney_core()","","\/\/ 2. VND → USD với tỷ giá mặc định","let result = try converter.convert(amount: 1_000_000, from: .VND, to: .USD, choose: .standard)","print(result.targetAmount)          \/\/ 39.292...","print(result.FormattedTargetAmount) \/\/ \"$ 39.2927\"","","\/\/ 3. USD → AUD","let result2 = try converter.convert(amount: 100, from: .USD, to: .AUD, choose: .standard)","","\/\/ 4. VND → AUD (qua USD trung gian)","let result3 = try converter.convert(amount: 5_000_000, from: .VND, to: .AUD, choose: .standard)","","\/\/ 5. Tỷ giá tuỳ chỉnh","let result4 = try converter.convert(amount: 1_000_000, from: .VND, to: .USD, choose: .customRate(25_800))","","\/\/ 6. Shorthand — chỉ lấy số tiền","let usd = try converter.vndToUsd(1_000_000) \/\/ → 39.292...","let vnd = try converter.usdToVnd(10)         \/\/ → 254500.0"],"syntax":"swift"},{"level":2,"type":"heading","text":"Xử lý lỗi","anchor":"X%E1%BB%AD-l%C3%BD-l%E1%BB%97i"},{"type":"codeListing","code":["do {","    let result = try converter.convert(amount: -100, from: .VND, to: .USD, choose: .standard)","} catch CurrenciesError.invalidAmount(let msg) {","    print(msg)","} catch CurrenciesError.invalidExchangeRates(let rate) {","    print(\"Tỷ giá không hợp lệ: \\(rate)\")","} catch CurrenciesError.unsupportedConversion(let from, let to) {","    print(\"Chưa hỗ trợ \\(from.rawValue) → \\(to.rawValue)\")","}"],"syntax":"swift"},{"name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Class này là "},{"type":"codeVoice","code":"final"},{"type":"text","text":" — không thể kế thừa."}],"type":"paragraph"}],"style":"note"}]}],"metadata":{"symbolKind":"class","externalID":"s:17transferMoney_SDK08TransferB5_coreC","navigatorTitle":[{"text":"TransferMoney_core","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TransferMoney_core","kind":"identifier"}],"modules":[{"name":"transferMoney SDK"}],"roleHeading":"Class","role":"symbol","title":"TransferMoney_core"},"identifier":{"url":"doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK"]]},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init()","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init(config:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/config"],"anchor":"Instance-Properties","generated":true},{"title":"Instance Methods","identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/convert(amount:from:to:choose:)","doc:\/\/transferMoney_SDK\/documentation\/tr