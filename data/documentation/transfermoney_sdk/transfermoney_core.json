{"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init()","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/init(config:)"],"generated":true},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/config"],"generated":true},{"anchor":"Instance-Methods","title":"Instance Methods","identifiers":["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/convert(amount:from:to:choose:)","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/updateExchangeRates(_:)","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/usdToVnd(_:)","doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/vndToUsd(_:)"],"generated":true}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core"},"metadata":{"roleHeading":"Class","symbolKind":"class","role":"symbol","title":"TransferMoney_core","externalID":"s:17transferMoney_SDK08TransferB5_coreC","modules":[{"name":"transferMoney_SDK"}],"navigatorTitle":[{"kind":"identifier","text":"TransferMoney_core"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"TransferMoney_core"}]},"abstract":[{"type":"strong","inlineContent":[{"type":"text","text":"Đây là class duy nhất bạn cần dùng"}]},{"type":"text","text":" để thực hiện chuyển đổi tiền tệ giữa VND, USD, và AUD."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TransferMoney_core","kind":"identifier"}]}]},{"content":[{"type":"heading","level":2,"text":"Các cặp tiền tệ được hỗ trợ","anchor":"C%C3%A1c-c%E1%BA%B7p-ti%E1%BB%81n-t%E1%BB%87-%C4%91%C6%B0%E1%BB%A3c-h%E1%BB%97-tr%E1%BB%A3"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"VND ↔ USD"}]}]},{"content":[{"inlineContent":[{"text":"USD ↔ AUD","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"VND ↔ AUD "},{"type":"emphasis","inlineContent":[{"text":"(tự động qua USD trung gian)","type":"text"}]}]}]}]},{"type":"heading","level":2,"text":"Quick Start","anchor":"Quick-Start"},{"type":"codeListing","code":["\/\/ 1. Khởi tạo","let converter = TransferMoney_core()","","\/\/ 2. VND → USD với tỷ giá mặc định","let result = try converter.convert(amount: 1_000_000, from: .VND, to: .USD, choose: .standard)","print(result.targetAmount)          \/\/ 39.292...","print(result.FormattedTargetAmount) \/\/ \"$ 39.2927\"","","\/\/ 3. USD → AUD","let result2 = try converter.convert(amount: 100, from: .USD, to: .AUD, choose: .standard)","","\/\/ 4. VND → AUD (qua USD trung gian)","let result3 = try converter.convert(amount: 5_000_000, from: .VND, to: .AUD, choose: .standard)","","\/\/ 5. Tỷ giá tuỳ chỉnh","let result4 = try converter.convert(amount: 1_000_000, from: .VND, to: .USD, choose: .customRate(25_800))","","\/\/ 6. Shorthand — chỉ lấy số tiền","let usd = try converter.vndToUsd(1_000_000) \/\/ → 39.292...","let vnd = try converter.usdToVnd(10)         \/\/ → 254500.0"],"syntax":"swift"},{"type":"heading","level":2,"text":"Xử lý lỗi","anchor":"X%E1%BB%AD-l%C3%BD-l%E1%BB%97i"},{"type":"codeListing","code":["do {","    let result = try converter.convert(amount: -100, from: .VND, to: .USD, choose: .standard)","} catch CurrenciesError.invalidAmount(let msg) {","    print(msg)","} catch CurrenciesError.invalidExchangeRates(let rate) {","    print(\"Tỷ giá không hợp lệ: \\(rate)\")","} catch CurrenciesError.unsupportedConversion(let from, let to) {","    print(\"Chưa hỗ trợ \\(from.rawValue) → \\(to.rawValue)\")","}"],"syntax":"swift"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Class này là ","type":"text"},{"code":"final","type":"codeVoice"},{"text":" — không thể kế thừa.","type":"text"}]}]}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/transfermoney_sdk\/transfermoney_core"]}],"references":{"doc://transferMoney_SDK/documentation/transferMoney_SDK/TransferMoney_core/vndToUsd(_:)":{"abstract":[{"type":"text","text":"Chuyển đổi VND sang USD (shorthand)."}],"role":"symbol","title":"vndToUsd(_:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"vndToUsd","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}],"url":"\/documentation\/transfermoney_sdk\/transfermoney_core\/vndtousd(_:)","type":"topic","identifier":"doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/vndToUsd(_:)"},"doc://transferMoney_SDK/documentation/transferMoney_SDK/TransferMoney_core/usdToVnd(_:)":{"role":"symbol","type":"topic","identifier":"doc:\/\/transferMoney_SDK\/documentation\/transferMoney_SDK\/TransferMoney_core\/usdToVnd(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"usdToVnd","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Double","kind":"ty